                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "Deletes node registration and detaches related sandbox scheduling metadata.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "orchestrator-node"
                ],
                "summary": "Delete node",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Node name",
                        "name": "name",
                        "in": "path",
                        "required": true
