# HTTP listen address
HTTP_ADDR=:8081

# containerd socket
SANDBOX_CONTAINERD_ADDRESS=/run/containerd/containerd.sock
SANDBOX_RUNTIME_BINARY=runsc
SANDBOX_CNI_CONF_PATH=/etc/cni/sandboxd.d/20-sbxnet.conflist

# local state/lock directories
SANDBOX_STATE_BASE_DIR=/var/lib/sandboxd/sandboxes
SANDBOX_LOCK_DIR=/var/lib/sandboxd/locks

# sandbox bridge/subnet
SANDBOX_BRIDGE_INTERFACE=sbx-br0
SANDBOX_SUBNET_CIDR=10.89.0.0/16
SANDBOX_MAX_ALLOC_PERCENT=90
SANDBOX_PROVISION_TIMEOUT=4m
SANDBOX_CONTAINER_CREATE_TIMEOUT=2m
SANDBOX_IMAGE_PULL_TIMEOUT=8m

# Chains to hook SANDBOX-FWD jump (comma-separated)
SANDBOX_FORWARD_HOOK_CHAINS=FORWARD,DOCKER-USER

# Optional: verbose provisioning/network debug logs
# true/1 enables detailed logs for VM/container lifecycle and iptables rule operations.
SANDBOX_DEBUG=true

# orchestrator
ORCH_HTTP_ADDR=:8082
ORCH_CONFIG_PATH=configs/apiserver.yaml
ORCH_SQLITE_PATH=/var/lib/sandboxd/orchestrator.db
ORCH_HEARTBEAT_INTERVAL=10s
ORCH_NODE_PROBE_TIMEOUT=3s
ORCH_READY_SUCCESS_THRESHOLD=2
ORCH_NOTREADY_FAILURE_THRESHOLD=2
ORCH_SHUTDOWN_TIMEOUT=5s
