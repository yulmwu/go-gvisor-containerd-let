{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Sandbox node agent API for gVisor-based sandbox lifecycle, runtime status, logs, and reconcile operations.",
        "title": "Sandboxd API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/healthz": {
            "get": {
                "description": "Returns service health.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-node"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.HealthResponse"
                        }
                    }
                }
            }
        },
        "/v1/node/status": {
            "get": {
                "description": "Returns unified node resource status used by orchestrator heartbeats and scheduling.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-node"
                ],
                "summary": "Get node resource snapshot",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.NodeStatusResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/reconcile": {
            "post": {
                "description": "Triggers one reconcile pass for orphan/runtime consistency cleanup.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-maintenance"
                ],
                "summary": "Trigger reconcile",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ReconcileResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/sandboxes": {
            "get": {
                "description": "Lists sandboxes with cursor-based pagination.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-sandbox"
                ],
                "summary": "List sandboxes",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Pagination cursor",
                        "name": "cursor",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Page size (default 20)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ListSandboxesResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Validates request, persists state, and starts asynchronous provisioning using CRI + runsc(gVisor).",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-sandbox"
                ],
                "summary": "Create sandbox (async)",
                "parameters": [
                    {
                        "description": "Create sandbox request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/model.CreateSandboxRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/httpserver.CreateSandboxResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/sandboxes/{id}": {
            "get": {
                "description": "Returns current sandbox state, including phase and container runtime status.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-sandbox"
                ],
                "summary": "Get sandbox",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Sandbox ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.GetSandboxResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "description": "Deletes sandbox runtime artifacts and persisted state.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-sandbox"
                ],
                "summary": "Delete sandbox",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Sandbox ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.DeleteSandboxResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/sandboxes/{id}/containers/{name}/logs": {
            "get": {
                "description": "Reads container logs with cursor pagination over byte offsets.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "sandboxd-logs"
                ],
                "summary": "Get container logs",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Sandbox ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Container name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Cursor offset",
                        "name": "cursor",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Max lines (default 100)",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ContainerLogsResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/httpserver.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "httpserver.ContainerLogsResponse": {
            "type": "object",
            "properties": {
                "container": {
                    "type": "string"
                },
                "external_ip": {
                    "type": "string"
                },
                "logs": {
                    "$ref": "#/definitions/sandbox.LogsPage"
                },
                "sandbox_id": {
                    "type": "string"
                }
            }
        },
        "httpserver.CreateSandboxResponse": {
            "type": "object",
            "properties": {
                "external_ip": {
                    "type": "string"
                },
                "sandbox": {
                    "$ref": "#/definitions/model.Sandbox"
                }
            }
        },
        "httpserver.DeleteSandboxResponse": {
            "type": "object",
            "properties": {
                "external_ip": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "phase": {
                    "type": "string"
                }
            }
        },
        "httpserver.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "httpserver.GetSandboxResponse": {
            "type": "object",
            "properties": {
                "external_ip": {
                    "type": "string"
                },
                "sandbox": {
                    "$ref": "#/definitions/model.Sandbox"
                }
            }
        },
        "httpserver.HealthResponse": {
            "type": "object",
            "properties": {
                "ok": {
                    "type": "boolean"
                }
            }
        },
        "httpserver.ListSandboxesResponse": {
            "type": "object",
            "properties": {
                "external_ip": {
                    "type": "string"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.Sandbox"
                    }
                },
                "next_cursor": {
                    "type": "string"
                }
            }
        },
        "httpserver.NodeStatusResponse": {
            "type": "object",
            "properties": {
                "ok": {
                    "type": "boolean"
                },
                "resources": {
                    "$ref": "#/definitions/model.NodeResourceSnapshot"
                }
            }
        },
        "httpserver.ReconcileResponse": {
            "type": "object",
            "properties": {
                "external_ip": {
                    "type": "string"
                },
                "ok": {
                    "type": "boolean"
                }
            }
        },
        "model.ContainerState": {
            "type": "object",
            "properties": {
                "args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "env": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "error": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "image": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "phase": {
                    "type": "string"
                },
                "resource": {
                    "$ref": "#/definitions/model.ResourceSpec"
                },
                "runtime": {
                    "type": "string"
                },
                "taskPID": {
                    "type": "integer"
                },
                "taskStatus": {
                    "type": "string"
                }
            }
        },
        "model.CreateContainerRequest": {
            "type": "object",
            "properties": {
                "args": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "env": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "image": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "resource": {
                    "$ref": "#/definitions/model.ResourceSpec"
                },
                "workDir": {
                    "type": "string"
                }
            }
        },
        "model.CreateSandboxRequest": {
            "type": "object",
            "properties": {
                "containers": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.CreateContainerRequest"
                    }
                },
                "egress": {
                    "type": "boolean"
                },
                "id": {
                    "type": "string"
                },
                "ports": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.PortMapping"
                    }
                }
            }
        },
        "model.NodeResourceSnapshot": {
            "type": "object",
            "properties": {
                "allocatable_cpu_milli": {
                    "type": "integer"
                },
                "allocatable_memory_bytes": {
                    "type": "integer"
                },
                "available_cpu_milli": {
                    "type": "integer"
                },
                "available_memory_bytes": {
                    "type": "integer"
                },
                "capacity_cpu_milli": {
                    "type": "integer"
                },
                "capacity_memory_bytes": {
                    "type": "integer"
                },
                "max_alloc_percent": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                },
                "used_cpu_milli": {
                    "type": "integer"
                },
                "used_memory_bytes": {
                    "type": "integer"
                }
            }
        },
        "model.PortMapping": {
            "type": "object",
            "properties": {
                "containerPort": {
                    "type": "integer"
                },
                "hostPort": {
                    "type": "integer"
                },
                "protocol": {
                    "type": "string"
                }
            }
        },
        "model.ResourceSpec": {
            "type": "object",
            "properties": {
                "cpu": {
                    "type": "string"
                },
                "memory": {
                    "type": "string"
                }
            }
        },
        "model.Sandbox": {
            "type": "object",
            "properties": {
                "bridgeName": {
                    "type": "string"
                },
                "cniConfPath": {
                    "type": "string"
                },
                "containers": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/model.ContainerState"
                    }
                },
                "createdAt": {
                    "type": "string"
                },
                "egress": {
                    "type": "boolean"
                },
                "error": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "ip": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "pauseID": {
                    "type": "string"
                },
                "phase": {
                    "type": "string"
                },
                "ports": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.PortMapping"
                    }
                },
                "subnetCIDR": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "sandbox.LogsPage": {
            "type": "object",
            "properties": {
                "has_more": {
                    "type": "boolean"
                },
                "lines": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "next_cursor": {
                    "type": "string"
                }
            }
        }
    }
}